{
  "name": "@nvmagic/node",
  "version": "0.1.0",
  "description": "NVMagic Node.js bindings via napi-rs",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./typed": {
      "types": "./typed.d.ts",
      "default": "./typed.js"
    }
  },
  "napi": {
    "name": "nvmagic",
    "triples": {}
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build-debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "license": "Apache-2.0"
}
