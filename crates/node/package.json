{
  "name": "@nvidia/nemo-flow-node",
  "version": "0.1.0",
  "description": "NeMo Flow Node.js bindings via napi-rs",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./typed": {
      "types": "./typed.d.ts",
      "default": "./typed.js"
    },
    "./plugin": {
      "types": "./plugin.d.ts",
      "default": "./plugin.js"
    },
    "./adaptive": {
      "types": "./adaptive.d.ts",
      "default": "./adaptive.js"
    }
  },
  "napi": {
    "name": "nemo-flow",
    "triples": {}
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build-debug": "napi build --platform",
    "precoverage": "npm run build-debug",
    "pretest": "npm run build-debug",
    "test": "node --test --test-force-exit tests/*.mjs",
    "coverage": "c8 --reporter=text --reporter=json-summary --reporter=cobertura --reports-dir coverage node --test --test-force-exit tests/*.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "c8": "^11.0.0"
  },
  "license": "Apache-2.0"
}
