new file mode 100644
index 0000000..9040214
--- /dev/null
+++ b/libs/core/langchain_core/utils/_nvmagic.py
@@ -0,0 +1,35 @@
+"""Lazy import helper for optional NVMagic integration.
+
+NVMagic is an optional dependency. All functions in this module are safe to
+call regardless of whether NVMagic is installed — they return ``None`` or
+``False`` when the package is not available.
+"""
+
+from __future__ import annotations
+
+import logging
+from types import ModuleType
+
+_logger = logging.getLogger(__name__)
+_nvmagic: ModuleType | None | bool = False  # False = not yet attempted
+
+
+def get_nvmagic() -> ModuleType | None:
+    """Return the ``nvmagic`` module, or ``None`` if not installed.
+
+    The import is performed lazily on first call and cached thereafter.
+    """
+    global _nvmagic  # noqa: PLW0603
+    if _nvmagic is False:
+        try:
+            import nvmagic  # type: ignore[import-untyped]
+
+            _nvmagic = nvmagic
+        except ImportError:
+            _nvmagic = None
+    return _nvmagic  # type: ignore[return-value]
+
+
+def is_available() -> bool:
+    """Return ``True`` if NVMagic is installed and importable."""
+    return get_nvmagic() is not None
