+"""Thin bridge module for optional NVMagic integration.
+
+When nvmagic is installed and a scope stack has been initialized by the
+caller, the helpers in this module route LLM calls through the full
+NVMagic middleware pipeline (guardrails, intercepts, execution intercepts).
+If nvmagic is not installed or no scope stack is active, ``available()``
+returns ``False`` and ChatOpenAI falls back to its vanilla code path.
+"""
+
+from __future__ import annotations
+
+import asyncio
+from concurrent.futures import ThreadPoolExecutor
+from typing import Any, Callable
+
+try:
+    import nvmagic
+
+    _HAS_NVMAGIC = True
+except ImportError:
+    _HAS_NVMAGIC = False
+
+
+def available() -> bool:
+    """Return True when nvmagic is importable *and* a scope stack is active."""
+    if not _HAS_NVMAGIC:
+        return False
+    try:
+        # Only consider nvmagic available if the caller has explicitly
+        # initialised a scope stack (we don't want to auto-create one).
+        return nvmagic._scope_stack_var.get(None) is not None
+    except Exception:
+        return False
+
+
+# ---------------------------------------------------------------------------
+# Sync-to-async bridge
+# ---------------------------------------------------------------------------
+
+
+def run_sync(coro: Any) -> Any:
+    """Run *coro* synchronously, handling the case where an event loop is
+    already running (e.g. Jupyter notebooks)."""
+    try:
+        asyncio.get_running_loop()
+    except RuntimeError:
+        # No loop running – we can just use asyncio.run.
+        return asyncio.run(coro)
+    # Loop already running – offload to a worker thread so we don't block.
+    with ThreadPoolExecutor(max_workers=1) as pool:
+        return pool.submit(asyncio.run, coro).result()
+
+
+# ---------------------------------------------------------------------------
+# LLM pipeline wrappers
+# ---------------------------------------------------------------------------
+
+
+async def llm_execute(
+    model_name: str,
+    payload: dict,
+    func: Callable[..., Any],
+) -> dict:
+    """Execute a non-streaming LLM call through the NVMagic pipeline."""
+    return await nvmagic.llm.execute(  # type: ignore[union-attr]
+        model_name,
+        payload,
+        func,
+        model_name=model_name,
+    )
+
+
+async def llm_stream_execute(
+    model_name: str,
+    payload: dict,
+    func: Callable[..., Any],
+    collector: Callable[[Any], None],
+    finalizer: Callable[[], Any],
+) -> Any:
+    """Execute a streaming LLM call through the NVMagic pipeline.
+
+    Returns an ``LlmStream`` async-iterable whose chunks have already
+    passed through stream-response intercepts.
+    """
+    return await nvmagic.llm.stream_execute(  # type: ignore[union-attr]
+        model_name,
+        payload,
+        func,
+        collector,
+        finalizer,
+        model_name=model_name,
+    )
