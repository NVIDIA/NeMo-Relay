@@ -0,0 +1,197 @@
+"""Tests for the NVMagic callback handler."""
+
+from __future__ import annotations
+
+from types import ModuleType, SimpleNamespace
+from typing import Any
+from unittest.mock import MagicMock
+from uuid import uuid4
+
+import pytest
+
+from langchain_core.callbacks.nvmagic_handler import (
+    NVMagicCallbackHandler,
+)
+
+
+# ---------------------------------------------------------------------------
+# Fixtures — mock NVMagic module
+# ---------------------------------------------------------------------------
+
+
+def _make_mock_nvmag() -> ModuleType:
+    """Build a minimal mock of the ``nvmagic`` module."""
+    nvmag = ModuleType("nvmagic")
+
+    # ScopeType enum
+    scope_type = SimpleNamespace(Agent="Agent")
+    nvmag.ScopeType = scope_type  # type: ignore[attr-defined]
+
+    # scope submodule
+    scope = MagicMock()
+    scope.push = MagicMock(side_effect=lambda name, st, **kw: SimpleNamespace(
+        uuid=str(uuid4()), name=name
+    ))
+    scope.pop = MagicMock()
+    nvmag.scope = scope  # type: ignore[attr-defined]
+
+    return nvmag
+
+
+@pytest.fixture()
+def mock_nvmag() -> ModuleType:
+    return _make_mock_nvmag()
+
+
+@pytest.fixture()
+def handler(mock_nvmag: ModuleType) -> NVMagicCallbackHandler:
+    h = NVMagicCallbackHandler()
+    h._nvmag = mock_nvmag
+    return h
+
+
+# ---------------------------------------------------------------------------
+# Tests — scope lifecycle
+# ---------------------------------------------------------------------------
+
+
+class TestScopeLifecycle:
+    """Verify that chain start/end/error map to scope push/pop."""
+
+    def test_on_chain_start_pushes_scope(
+        self, handler: NVMagicCallbackHandler, mock_nvmag: ModuleType
+    ) -> None:
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"name": "MyChain"},
+            {"input": "test"},
+            run_id=run_id,
+        )
+        mock_nvmag.scope.push.assert_called_once()
+        assert run_id in handler._scope_handles
+
+    def test_on_chain_end_pops_scope(
+        self, handler: NVMagicCallbackHandler, mock_nvmag: ModuleType
+    ) -> None:
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"name": "MyChain"},
+            {"input": "test"},
+            run_id=run_id,
+        )
+        handler.on_chain_end(
+            {"output": "result"},
+            run_id=run_id,
+        )
+        mock_nvmag.scope.pop.assert_called_once()
+        assert run_id not in handler._scope_handles
+
+    def test_on_chain_error_pops_scope(
+        self, handler: NVMagicCallbackHandler, mock_nvmag: ModuleType
+    ) -> None:
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"name": "MyChain"},
+            {"input": "test"},
+            run_id=run_id,
+        )
+        handler.on_chain_error(
+            RuntimeError("boom"),
+            run_id=run_id,
+        )
+        mock_nvmag.scope.pop.assert_called_once()
+        assert run_id not in handler._scope_handles
+
+    def test_parent_scope_passed_to_push(
+        self, handler: NVMagicCallbackHandler, mock_nvmag: ModuleType
+    ) -> None:
+        parent_id = uuid4()
+        child_id = uuid4()
+        handler.on_chain_start(
+            {"name": "Parent"},
+            {},
+            run_id=parent_id,
+        )
+        parent_handle = handler._scope_handles[parent_id]
+        handler.on_chain_start(
+            {"name": "Child"},
+            {},
+            run_id=child_id,
+            parent_run_id=parent_id,
+        )
+        # The second call should pass the parent handle
+        call_kwargs = mock_nvmag.scope.push.call_args_list[1]
+        assert call_kwargs.kwargs.get("handle") is parent_handle
+
+    def test_chain_end_without_start_is_noop(
+        self, handler: NVMagicCallbackHandler, mock_nvmag: ModuleType
+    ) -> None:
+        """Ending a scope that was never started should not raise."""
+        handler.on_chain_end(
+            {"output": "result"},
+            run_id=uuid4(),
+        )
+        mock_nvmag.scope.pop.assert_not_called()
+
+    def test_name_fallback_to_id(
+        self, handler: NVMagicCallbackHandler, mock_nvmag: ModuleType
+    ) -> None:
+        """If 'name' is missing, fall back to last element of 'id'."""
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"id": ["langchain", "core", "RunnableSequence"]},
+            {},
+            run_id=run_id,
+        )
+        name_arg = mock_nvmag.scope.push.call_args[0][0]
+        assert name_arg == "RunnableSequence"
+
+
+# ---------------------------------------------------------------------------
+# Tests — graceful no-op when NVMagic is not installed
+# ---------------------------------------------------------------------------
+
+
+class TestGracefulNoOp:
+    """Verify the handler is a silent no-op when NVMagic is absent."""
+
+    def test_no_nvmag_on_chain_start(self) -> None:
+        h = NVMagicCallbackHandler()
+        h._nvmag = None
+        h.on_chain_start({"name": "x"}, {}, run_id=uuid4())
+
+    def test_no_nvmag_on_chain_end(self) -> None:
+        h = NVMagicCallbackHandler()
+        h._nvmag = None
+        h.on_chain_end({}, run_id=uuid4())
+
+    def test_no_nvmag_on_chain_error(self) -> None:
+        h = NVMagicCallbackHandler()
+        h._nvmag = None
+        h.on_chain_error(RuntimeError("e"), run_id=uuid4())
+
+
+# ---------------------------------------------------------------------------
+# Tests — error swallowing
+# ---------------------------------------------------------------------------
+
+
+class TestErrorSwallowing:
+    """Ensure NVMagic errors never propagate."""
+
+    def test_scope_push_error_swallowed(self, mock_nvmag: ModuleType) -> None:
+        mock_nvmag.scope.push.side_effect = RuntimeError("nvmag failure")
+        h = NVMagicCallbackHandler()
+        h._nvmag = mock_nvmag
+        # Should not raise
+        h.on_chain_start({"name": "x"}, {}, run_id=uuid4())
+
+    def test_scope_pop_error_swallowed(self, mock_nvmag: ModuleType) -> None:
+        mock_nvmag.scope.pop.side_effect = RuntimeError("nvmag failure")
+        h = NVMagicCallbackHandler()
+        h._nvmag = mock_nvmag
+        run_id = uuid4()
+        h.on_chain_start({"name": "x"}, {}, run_id=run_id)
+        # Reset the push side effect for pop to work
+        mock_nvmag.scope.pop.side_effect = RuntimeError("nvmag failure")
+        h.on_chain_end({}, run_id=run_id)
