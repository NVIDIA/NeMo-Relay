+"""Thin bridge module for optional Nexus integration.
+
+When nat_nexus is installed and a scope stack has been initialized by the
+caller, the helpers in this module route LLM calls through the full
+Nexus middleware pipeline (guardrails, intercepts, execution intercepts).
+If nat_nexus is not installed or no scope stack is active, ``available()``
+returns ``False`` and ChatOpenAI falls back to its vanilla code path.
+
+All LLM calls flow through the **typed** Nexus API
+(``nat_nexus.typed.llm_execute`` / ``nat_nexus.typed.llm_stream_execute``)
+with ``JsonPassthrough`` since the ``_call`` helpers already convert SDK
+responses to plain dicts (via ``model_dump()``) before returning.
+"""
+
+from __future__ import annotations
+
+import asyncio
+from concurrent.futures import ThreadPoolExecutor
+from typing import Any, Callable
+
+try:
+    import nat_nexus
+    from nat_nexus import LLMRequest
+
+    _HAS_NAT_NEXUS = True
+except ImportError:
+    _HAS_NAT_NEXUS = False
+
+
+def available() -> bool:
+    """Return True when nat_nexus is importable *and* a scope stack is active."""
+    if not _HAS_NAT_NEXUS:
+        return False
+    try:
+        # Only consider nat_nexus available if the caller has explicitly
+        # initialised a scope stack (we don't want to auto-create one).
+        return nat_nexus.scope_stack_active()
+    except Exception:
+        return False
+
+
+def make_request(payload: dict, extra_headers: dict | None = None) -> "LLMRequest":
+    """Wrap a payload dict and optional extra headers into an LLMRequest."""
+    return LLMRequest(extra_headers or {}, payload)
+
+
+# ---------------------------------------------------------------------------
+# Sync-to-async bridge
+# ---------------------------------------------------------------------------
+
+
+def run_sync(coro: Any) -> Any:
+    """Run *coro* synchronously, handling the case where an event loop is
+    already running (e.g. Jupyter notebooks)."""
+    try:
+        asyncio.get_running_loop()
+    except RuntimeError:
+        # No loop running – we can just use asyncio.run.
+        return asyncio.run(coro)
+    # Loop already running – offload to a worker thread so we don't block.
+    with ThreadPoolExecutor(max_workers=1) as pool:
+        return pool.submit(asyncio.run, coro).result()
+
+
+# ---------------------------------------------------------------------------
+# LLM pipeline wrappers (typed API)
+# ---------------------------------------------------------------------------
+
+
+async def llm_execute(
+    model_name: str,
+    request: "LLMRequest",
+    func: Callable[..., Any],
+) -> Any:
+    """Execute a non-streaming LLM call through the Nexus typed pipeline.
+
+    The *func* callable receives an ``LLMRequest`` and returns a dict
+    (already converted from the SDK response via ``model_dump()``).
+    ``JsonPassthrough`` passes dicts through with zero overhead.
+    """
+    codec = nat_nexus.typed.JsonPassthrough()
+    return await nat_nexus.typed.llm_execute(  # type: ignore[union-attr]
+        model_name,
+        request,
+        func,
+        codec,
+        model_name=model_name,
+    )
+
+
+async def llm_stream_execute(
+    model_name: str,
+    request: "LLMRequest",
+    func: Callable[..., Any],
+    collector: Callable[[Any], None],
+    finalizer: Callable[[], Any],
+) -> Any:
+    """Execute a streaming LLM call through the Nexus typed pipeline.
+
+    The *func* callable receives an ``LLMRequest`` and should return an
+    async iterator of dict chunks (already converted via ``model_dump()``).
+    ``JsonPassthrough`` passes each chunk through with zero overhead.
+    Returns an ``LlmStream`` async-iterable whose chunks have already
+    passed through stream-response intercepts.
+    """
+    codec = nat_nexus.typed.JsonPassthrough()
+    return await nat_nexus.typed.llm_stream_execute(  # type: ignore[union-attr]
+        model_name,
+        request,
+        func,
+        collector,
+        finalizer,
+        codec,
+        codec,
+        model_name=model_name,
+    )
