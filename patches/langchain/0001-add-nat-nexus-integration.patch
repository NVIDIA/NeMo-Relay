@@ -0,0 +1,197 @@
+"""Tests for the Nexus callback handler."""
+
+from __future__ import annotations
+
+from types import ModuleType, SimpleNamespace
+from typing import Any
+from unittest.mock import MagicMock
+from uuid import uuid4
+
+import pytest
+
+from langchain_core.callbacks.nat_nexus_handler import (
+    NatNexusCallbackHandler,
+)
+
+
+# ---------------------------------------------------------------------------
+# Fixtures — mock Nexus module
+# ---------------------------------------------------------------------------
+
+
+def _make_mock_nnex() -> ModuleType:
+    """Build a minimal mock of the ``nat_nexus`` module."""
+    nnex = ModuleType("nat_nexus")
+
+    # ScopeType enum
+    scope_type = SimpleNamespace(Agent="Agent")
+    nnex.ScopeType = scope_type  # type: ignore[attr-defined]
+
+    # scope submodule
+    scope = MagicMock()
+    scope.push = MagicMock(side_effect=lambda name, st, **kw: SimpleNamespace(
+        uuid=str(uuid4()), name=name
+    ))
+    scope.pop = MagicMock()
+    nnex.scope = scope  # type: ignore[attr-defined]
+
+    return nnex
+
+
+@pytest.fixture()
+def mock_nnex() -> ModuleType:
+    return _make_mock_nnex()
+
+
+@pytest.fixture()
+def handler(mock_nnex: ModuleType) -> NatNexusCallbackHandler:
+    h = NatNexusCallbackHandler()
+    h._nnex = mock_nnex
+    return h
+
+
+# ---------------------------------------------------------------------------
+# Tests — scope lifecycle
+# ---------------------------------------------------------------------------
+
+
+class TestScopeLifecycle:
+    """Verify that chain start/end/error map to scope push/pop."""
+
+    def test_on_chain_start_pushes_scope(
+        self, handler: NatNexusCallbackHandler, mock_nnex: ModuleType
+    ) -> None:
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"name": "MyChain"},
+            {"input": "test"},
+            run_id=run_id,
+        )
+        mock_nnex.scope.push.assert_called_once()
+        assert run_id in handler._scope_handles
+
+    def test_on_chain_end_pops_scope(
+        self, handler: NatNexusCallbackHandler, mock_nnex: ModuleType
+    ) -> None:
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"name": "MyChain"},
+            {"input": "test"},
+            run_id=run_id,
+        )
+        handler.on_chain_end(
+            {"output": "result"},
+            run_id=run_id,
+        )
+        mock_nnex.scope.pop.assert_called_once()
+        assert run_id not in handler._scope_handles
+
+    def test_on_chain_error_pops_scope(
+        self, handler: NatNexusCallbackHandler, mock_nnex: ModuleType
+    ) -> None:
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"name": "MyChain"},
+            {"input": "test"},
+            run_id=run_id,
+        )
+        handler.on_chain_error(
+            RuntimeError("boom"),
+            run_id=run_id,
+        )
+        mock_nnex.scope.pop.assert_called_once()
+        assert run_id not in handler._scope_handles
+
+    def test_parent_scope_passed_to_push(
+        self, handler: NatNexusCallbackHandler, mock_nnex: ModuleType
+    ) -> None:
+        parent_id = uuid4()
+        child_id = uuid4()
+        handler.on_chain_start(
+            {"name": "Parent"},
+            {},
+            run_id=parent_id,
+        )
+        parent_handle = handler._scope_handles[parent_id]
+        handler.on_chain_start(
+            {"name": "Child"},
+            {},
+            run_id=child_id,
+            parent_run_id=parent_id,
+        )
+        # The second call should pass the parent handle
+        call_kwargs = mock_nnex.scope.push.call_args_list[1]
+        assert call_kwargs.kwargs.get("handle") is parent_handle
+
+    def test_chain_end_without_start_is_noop(
+        self, handler: NatNexusCallbackHandler, mock_nnex: ModuleType
+    ) -> None:
+        """Ending a scope that was never started should not raise."""
+        handler.on_chain_end(
+            {"output": "result"},
+            run_id=uuid4(),
+        )
+        mock_nnex.scope.pop.assert_not_called()
+
+    def test_name_fallback_to_id(
+        self, handler: NatNexusCallbackHandler, mock_nnex: ModuleType
+    ) -> None:
+        """If 'name' is missing, fall back to last element of 'id'."""
+        run_id = uuid4()
+        handler.on_chain_start(
+            {"id": ["langchain", "core", "RunnableSequence"]},
+            {},
+            run_id=run_id,
+        )
+        name_arg = mock_nnex.scope.push.call_args[0][0]
+        assert name_arg == "RunnableSequence"
+
