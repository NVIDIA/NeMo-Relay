diff --git a/src/nvmagic/index.ts b/src/nvmagic/index.ts
new file mode 100644
index 000000000..be0e9ccb2
--- /dev/null
+++ b/src/nvmagic/index.ts
@@ -0,0 +1,239 @@
+// SPDX-License-Identifier: Apache-2.0
+import type { StreamFn } from "@mariozechner/pi-agent-core";
+import { createSubsystemLogger } from "../logging/subsystem.js";
+
+const log = createSubsystemLogger("nvmagic");
+
+let lib: any = null;
+let typedLib: any = null;
+let enabled = false;
+let initDone = false;
+
+const exporters = new Map<string, any>();
+
+export namespace NVMagic {
+  export async function init(): Promise<boolean> {
+    if (initDone) return enabled;
+    initDone = true;
+    if (!process.env.NVMAGIC_ENABLED) return false;
+
+    try {
+      lib = await import("@nvmagic/node");
+      typedLib = await import("@nvmagic/node/typed");
+      enabled = true;
+      log.info("initialized");
+    } catch (e) {
+      log.warn("native addon not available, disabling", { error: String(e) });
+      enabled = false;
+    }
+
+    return enabled;
+  }
+
+  export function isEnabled(): boolean {
+    return enabled;
+  }
+
+  // ---------------------------------------------------------------------------
+  // Scope stack isolation — one per session to prevent cross-session bleed
+  // ---------------------------------------------------------------------------
+
+  export function createScopeStack(): unknown {
+    if (!enabled || !lib) return null;
+    try {
+      return lib.createScopeStack();
+    } catch (e) {
+      log.error("createScopeStack failed", { error: String(e) });
+      return null;
+    }
+  }
+
+  export function setThreadScopeStack(stack: unknown): void {
+    if (!enabled || !lib || !stack) return;
+    try {
+      lib.setThreadScopeStack(stack);
+    } catch (e) {
+      log.error("setThreadScopeStack failed", { error: String(e) });
+    }
+  }
+
+  // ---------------------------------------------------------------------------
+  // Scope management
+  // ---------------------------------------------------------------------------
+
+  export function pushAgentScope(name: string): unknown {
+    if (!enabled || !lib) return null;
+    try {
+      return lib.pushScope(name, 0 /* ScopeType.Agent */);
+    } catch (e) {
+      log.error("pushAgentScope failed", { error: String(e) });
+      return null;
+    }
+  }
+
+  export function popScope(handle: unknown): void {
+    if (!enabled || !lib || !handle) return;
+    try {
+      lib.popScope(handle);
+    } catch (e) {
+      log.error("popScope failed", { error: String(e) });
+    }
+  }
+
+  // ---------------------------------------------------------------------------
+  // Tool execution wrapping
+  // ---------------------------------------------------------------------------
+
+  export async function wrapToolExecute<T>(
+    name: string,
+    args: any,
+    fn: (args: any) => Promise<T>,
+  ): Promise<T> {
+    if (!enabled || !lib) return fn(args);
+    try {
+      let originalResult: T;
+      await lib.toolCallExecuteAsync(name, args, async (a: any) => {
+        originalResult = await fn(a);
+        return originalResult;
+      }, null, null, null, null);
+      return originalResult!;
+    } catch (e) {
+      log.error("wrapToolExecute failed", { error: String(e) });
+      return fn(args);
+    }
+  }
+
+  // ---------------------------------------------------------------------------
+  // StreamFn wrapping — adapts pi-agent-core StreamFn for NVMagic lifecycle
+  // ---------------------------------------------------------------------------
+  // Chunks pass through the full NAPI JSON round-trip so that intercept
+  // transformations are reflected in the yielded events.
+
+  export function wrapStreamFn(baseFn: StreamFn): StreamFn {
+    if (!enabled || !typedLib) return baseFn;
+
+    return ((model: any, context: any, options: any) => {
+      const modelName = typeof model?.id === "string" ? model.id : String(model);
+      const providerName = typeof model?.provider === "string" ? model.provider : modelName;
+
+      const request = {
+        headers: { ...options?.headers },
+        content: { model: modelName, provider: providerName },
+      };
+
+      const passthrough = new typedLib.JsonPassthrough();
+      const collected: any[] = [];
+      const responseChunks: string[] = [];
+      const toolCalls: any[] = [];
+
+      return {
+        async *[Symbol.asyncIterator]() {
+          try {
+            const nvStream = await typedLib.typedLlmStreamExecute(
+              providerName,
+              request,
+              (interceptedReq: any) => {
+                const extraHeaders = interceptedReq?.headers;
+                if (extraHeaders && Object.keys(extraHeaders).length > 0) {
+                  options = {
+                    ...options,
+                    headers: { ...options?.headers, ...extraHeaders },
+                  };
+                }
+                return baseFn(model, context, options);
+              },
+              (chunk: any) => {
+                collected.push(chunk);
+                // Accumulate for the finalizer's response summary
+                const eventType = chunk?.type;
+                if (eventType === "text" && typeof chunk?.text === "string") {
+                  responseChunks.push(chunk.text);
+                } else if (eventType === "tool_call" || eventType === "tool-call") {
+                  toolCalls.push({
+                    id: chunk.toolCallId ?? chunk.id,
+                    type: "function",
+                    function: {
+                      name: chunk.toolName ?? chunk.name,
+                      arguments: JSON.stringify(chunk.input ?? chunk.args ?? {}),
+                    },
+                  });
+                }
+              },
+              () => {
+                const result: any = {
+                  role: "assistant",
+                  content: responseChunks.join("") || null,
+                };
+                if (toolCalls.length > 0) {
+                  result.tool_calls = toolCalls;
+                }
+                return result;
+              },
+              passthrough,
+              passthrough,
+              {
+                attributes: lib.LLM_ATTR_STREAMING,
+                modelName,
+              },
+            );
+
+            while ((await nvStream.next()) !== null) {
+              while (collected.length > 0) {
+                yield collected.shift();
+              }
+            }
+            while (collected.length > 0) {
+              yield collected.shift();
+            }
+          } catch (e) {
+            log.error("wrapStreamFn failed, falling back to unwrapped", { error: String(e) });
+            yield* baseFn(model, context, options);
+          }
+        },
+      } as any;
+    }) as StreamFn;
+  }
+
+  // ---------------------------------------------------------------------------
+  // ATIF export
+  // ---------------------------------------------------------------------------
+
+  export function hasExporter(sessionId: string): boolean {
+    return exporters.has(sessionId);
+  }
+
+  export function createExporter(sessionId: string, agentName: string): unknown {
+    if (!enabled || !lib) return null;
+    try {
+      const exporter = new lib.JsAtifExporter(sessionId, agentName, "1.0.0", null);
+      exporter.register(`atif-${sessionId}`);
+      exporters.set(sessionId, exporter);
+      return exporter;
+    } catch (e) {
+      log.error("createExporter failed", { error: String(e) });
+      return null;
+    }
+  }
+
+  export function exportTrajectory(sessionId: string, rootUuid?: string): string | null {
+    const exporter = exporters.get(sessionId);
+    if (!exporter) return null;
+    try {
+      return exporter.exportJson(rootUuid ?? null);
+    } catch (e) {
+      log.error("exportTrajectory failed", { error: String(e) });
+      return null;
+    }
+  }
+
+  export function clearExporter(sessionId: string): void {
+    const exporter = exporters.get(sessionId);
+    if (!exporter) return;
+    try {
+      exporter.deregister(`atif-${sessionId}`);
+      exporters.delete(sessionId);
+    } catch (e) {
+      log.error("clearExporter failed", { error: String(e) });
+    }
+  }
+}
