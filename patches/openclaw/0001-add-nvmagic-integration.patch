@@ -0,0 +1,43 @@
+// SPDX-License-Identifier: Apache-2.0
+import { definePluginEntry, type OpenClawPluginApi } from "openclaw/plugin-sdk/core";
+import { NVMagic } from "../../src/nvmagic/index.js";
+
+export default definePluginEntry({
+  id: "nvmagic",
+  name: "NVMagic Tracing",
+  description: "NVMagic agent tracing and ATIF trajectory export",
+
+  register(api: OpenClawPluginApi) {
+    api.on("gateway_start", async () => {
+      await NVMagic.init();
+      if (NVMagic.isEnabled()) {
+        api.logger.info("nvmagic: tracing enabled");
+      }
+    });
+
+    api.on("session_start", async (event) => {
+      if (!NVMagic.isEnabled()) return;
+      if (!NVMagic.hasExporter(event.sessionId)) {
+        NVMagic.createExporter(event.sessionId, "openclaw");
+      }
+    });
+
+    api.on("session_end", async (event) => {
+      if (!NVMagic.isEnabled()) return;
+      if (!NVMagic.hasExporter(event.sessionId)) return;
+
+      const trajectory = NVMagic.exportTrajectory(event.sessionId);
+      if (trajectory) {
+        const fs = await import("node:fs/promises");
+        const path = await import("node:path");
+        const os = await import("node:os");
+        const atifDir = path.join(os.homedir(), ".openclaw", "atif");
+        await fs.mkdir(atifDir, { recursive: true });
+        const filePath = path.join(atifDir, `${event.sessionId}.json`);
+        await fs.writeFile(filePath, trajectory);
+        api.logger.info(`nvmagic: exported ATIF trajectory to ${filePath}`);
+      }
+      NVMagic.clearExporter(event.sessionId);
+    });
+  },
+});
