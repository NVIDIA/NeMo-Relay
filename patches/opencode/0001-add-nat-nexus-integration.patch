diff --git a/packages/opencode/src/nat_nexus/index.ts b/packages/opencode/src/nat_nexus/index.ts
new file mode 100644
index 000000000..367966404
--- /dev/null
+++ b/packages/opencode/src/nat_nexus/index.ts
@@ -0,0 +1,259 @@
+import { Log } from "../util/log"
+import { Flag } from "../flag/flag"
+
+const log = Log.create({ service: "nat_nexus" })
+
+let lib: any = null
+let typedLib: any = null
+let enabled = false
+let initDone = false
+
+const exporters = new Map<string, any>()
+
+export namespace NatNexus {
+  export let SCOPE_ATTR_PARALLEL = 0
+
+  export async function init(config?: { nat_nexus?: boolean }): Promise<boolean> {
+    if (initDone) return enabled
+    initDone = true
+    if (!Flag.NAT_NEXUS_ENABLED && !config?.nat_nexus) return false
+
+    try {
+      lib = await import("@nvidia/nat-nexus-node")
+      typedLib = await import("@nvidia/nat-nexus-node/typed")
+      enabled = true
+      SCOPE_ATTR_PARALLEL = lib.SCOPE_ATTR_PARALLEL ?? 0
+      log.info("initialized")
+    } catch (e) {
+      log.warn("native addon not available, disabling", { error: e })
+      enabled = false
+    }
+
+    return enabled
+  }
+
+  export function isEnabled(): boolean {
+    return enabled
+  }
+
+  export function pushAgentScope(name: string) {
+    if (!enabled || !lib) return null
+    try {
+      return lib.pushScope(name, 0 /* ScopeType.Agent */)
+    } catch (e) {
+      log.error("pushAgentScope", { error: e })
+      return null
+    }
+  }
+
+  export function pushFunctionScope(name: string, attributes?: number) {
+    if (!enabled || !lib) return null
+    try {
+      return lib.pushScope(name, 1 /* ScopeType.Function */, null, attributes ?? null)
+    } catch (e) {
+      log.error("pushFunctionScope", { error: e })
+      return null
+    }
+  }
+
+  export function popScope(handle: unknown) {
+    if (!enabled || !lib || !handle) return
+    try {
+      lib.popScope(handle)
+    } catch (e) {
+      log.error("popScope", { error: e })
+    }
+  }
+
+  export async function wrapToolExecute<T>(
+    name: string,
+    args: any,
+    fn: (args: any) => Promise<T>,
+  ): Promise<T> {
+    if (!enabled || !lib) return fn(args)
+    try {
+      // Capture the original JS result to avoid the lossy NAPI JSON round-trip.
+      // Tool results may contain non-JSON types (class instances, LSP diagnostics)
+      // that don't survive serde_json serialization. NatNexus still sees a JSON copy
+      // for its events/intercepts; the caller gets the original object.
+      let originalResult: T
+      await lib.toolCallExecuteAsync(name, args, async (a: any) => {
+        originalResult = await fn(a)
+        return originalResult
+      }, null, null, null, null)
+      return originalResult!
+    } catch (e) {
+      log.error("wrapToolExecute", { error: e })
+      return fn(args)
+    }
+  }
+
+  // ---------------------------------------------------------------------------
+  // StreamInput codec — bidirectional serialization across the NAPI boundary
+  // ---------------------------------------------------------------------------
+  // Strips non-JSON-serializable fields (AbortSignal, Tool functions) during
+  // encoding. After NatNexus intercepts potentially modify the serializable
+  // subset, applyIntercepted merges changes back while restoring the stripped
+  // fields from the original.
+
+  function encodeStreamInput(input: any): any {
+    const { abort: _abort, tools, ...rest } = input
+    return {
+      ...rest,
+      toolNames: Object.keys(tools),
+    }
+  }
+
+  function applyIntercepted(input: any, intercepted: any): void {
+    if (!intercepted) return
+    const { toolNames: _tn, ...fields } = intercepted
+    Object.assign(input, fields)
+  }
+
+  // ---------------------------------------------------------------------------
+  // wrapLlmStream — uses typedLlmStreamExecute with codecs
+  // ---------------------------------------------------------------------------
+
+  export async function* wrapLlmStream(
+    streamInput: any,
+    streamFn: () => AsyncIterable<any>,
+  ): AsyncGenerator<any> {
+    if (!enabled || !typedLib) {
+      yield* streamFn()
+      return
+    }
+    try {
+      const request = {
+        headers: {},
+        content: encodeStreamInput(streamInput),
+      }
+
+      // Buffer original AI SDK events — they contain non-serializable objects
+      // (Error instances, class instances) that can't survive NAPI JSON
+      // round-tripping, so we never pass them through serde.
+      const originals: any[] = []
+      const responseChunks: string[] = []
+      const toolCalls: any[] = []
+
+      // Chunk codec: toJson buffers the original and emits a JSON-safe marker;
+      // fromJson returns the buffered original so the collector sees real events.
+      const chunkCodec = {
+        toJson(event: any): any {
+          originals.push(event)
+          if (event.type === "text-delta" && event.text) {
+            responseChunks.push(event.text)
+          } else if (event.type === "tool-call") {
+            toolCalls.push({
+              id: event.toolCallId,
+              type: "function",
+              function: {
+                name: event.toolName,
+                arguments: JSON.stringify(event.input ?? {}),
+              },
+            })
+          }
+          return { _t: event.type ?? "chunk" }
+        },
+        fromJson(_data: any): any {
+          return originals.shift()
+        },
+      }
+
+      // Response codec: the ATIF finalizer response is already JSON-safe.
+      const responseCodec = new typedLib.JsonPassthrough()
+
+      const collected: any[] = []
+
+      const nvStream = await typedLib.typedLlmStreamExecute(
+        streamInput.model.providerID,
+        request,
+        (interceptedReq: any) => {
+          // Apply intercepted request changes back to streamInput before
+          // streamFn() reads it — streamFn captures streamInput by reference.
+          applyIntercepted(streamInput, interceptedReq?.content)
+          // Bridge NatNexus-intercepted headers to the AI SDK HTTP request.
+          if (interceptedReq?.headers && Object.keys(interceptedReq.headers).length > 0) {
+            streamInput.extraHeaders = interceptedReq.headers
+          }
+          return streamFn()
+        },
+        (chunk: any) => {
+          collected.push(chunk)
+        },
+        () => {
+          const result: any = {
+            role: "assistant",
+            content: responseChunks.join("") || null,
+          }
+          if (toolCalls.length > 0) {
+            result.tool_calls = toolCalls
+          }
+          return result
+        },
+        chunkCodec,
+        responseCodec,
+        {
+          attributes: lib.LLM_ATTR_STREAMING,
+          modelName: streamInput.model.id,
+        },
+      )
+
+      // Drain NatNexus stream (drives lifecycle/intercepts) and yield collected events
+      while ((await nvStream.next()) !== null) {
+        while (collected.length > 0) {
+          yield collected.shift()
+        }
+      }
+      // Yield any remaining buffered events
+      while (collected.length > 0) {
+        yield collected.shift()
+      }
+    } catch (e) {
+      log.error("wrapLlmStream", { error: e })
+      yield* streamFn()
+    }
+  }
+
+  export function hasExporter(sessionId: string): boolean {
+    return exporters.has(sessionId)
+  }
+
+  export function createExporter(
+    sessionId: string,
+    agentName: string,
+    modelName?: string,
+  ) {
+    if (!enabled || !lib) return null
+    try {
+      const exporter = new lib.JsAtifExporter(sessionId, agentName, "1.0.0", modelName ?? null)
+      exporter.register(`atif-${sessionId}`)
+      exporters.set(sessionId, exporter)
+      return exporter
+    } catch (e) {
+      log.error("createExporter", { error: e })
+      return null
+    }
+  }
+
+  export function exportTrajectory(sessionId: string): string | null {
+    const exporter = exporters.get(sessionId)
+    if (!exporter) return null
+    try {
+      return exporter.exportJson()
+    } catch (e) {
+      log.error("exportTrajectory", { error: e })
+      return null
+    }
+  }
+
+  export function clearExporter(sessionId: string) {
+    const exporter = exporters.get(sessionId)
+    if (!exporter) return
+    try {
+      exporter.deregister(`atif-${sessionId}`)
+      exporters.delete(sessionId)
+    } catch (e) {
+      log.error("clearExporter", { error: e })
+    }
+  }
+}
