diff --git a/packages/opencode/src/plugin/nat_nexus.ts b/packages/opencode/src/plugin/nat_nexus.ts
new file mode 100644
index 000000000..1344001b1
--- /dev/null
+++ b/packages/opencode/src/plugin/nat_nexus.ts
@@ -0,0 +1,50 @@
+import type { Hooks, Plugin as PluginInstance } from "@opencode-ai/plugin"
+import { Config } from "../config/config"
+import { NatNexus } from "../nat_nexus"
+import { Global } from "../global"
+import { Log } from "../util/log"
+import path from "path"
+import fs from "fs/promises"
+
+const log = Log.create({ service: "plugin.nat_nexus" })
+
+export const NatNexusPlugin: PluginInstance = async (_input) => {
+  const config = await Config.get()
+  const enabled = await NatNexus.init({ nat_nexus: config.experimental?.nat_nexus })
+  if (!enabled) return {}
+
+  const atifDir = path.join(Global.Path.data, "atif")
+  await fs.mkdir(atifDir, { recursive: true })
+
+  return {
+    "chat.message": async (hookInput, _output) => {
+      if (!NatNexus.hasExporter(hookInput.sessionID)) {
+        const modelStr = hookInput.model
+          ? `${hookInput.model.providerID}/${hookInput.model.modelID}`
+          : undefined
+        NatNexus.createExporter(
+          hookInput.sessionID,
+          hookInput.agent ?? "opencode",
+          modelStr,
+        )
+      }
+    },
+
+    event: async ({ event }) => {
+      // Auto-export ATIF trajectory when session goes idle
+      const props = (event as any).properties
+      if ((event as any).type === "session.status" && props?.status?.type === "idle") {
+        const sessionID = props.sessionID as string
+        if (!sessionID || !NatNexus.hasExporter(sessionID)) return
+
+        const trajectory = NatNexus.exportTrajectory(sessionID)
+        if (!trajectory) return
+
+        const filePath = path.join(atifDir, `${sessionID}.json`)
+        await fs.writeFile(filePath, trajectory)
+        log.info("exported ATIF trajectory", { sessionID, path: filePath })
+        NatNexus.clearExporter(sessionID)
+      }
+    },
+  } satisfies Hooks
+}
