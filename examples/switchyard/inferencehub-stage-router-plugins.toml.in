version = 1

[[components]]
kind = "switchyard"
enabled = true

[components.config]
mode = "enforce"
decision_api_url = "http://127.0.0.1:4000/v1/routing/decision"
decision_profile_id = "claude-4-6-stage-router"
request_materialization = "full_body"
context_mode = "atof_required"
decision_timeout_millis = 120000
max_retries = 3
recent_message_count = 8

[components.config.decision_header_env]
authorization = "SWITCHYARD_AUTHORIZATION"

[components.config.default_targets]
openai_chat = "claude-sonnet-4-6"
openai_responses = "sonnet-responses"
anthropic_messages = "sonnet-anthropic"

[components.config.targets.claude-sonnet-4-6]
model = "azure/anthropic/claude-sonnet-4-6"
protocol = "openai_chat"
endpoint = "/v1/chat/completions"
base_url = "https://inference-api.nvidia.com"

[components.config.targets.claude-sonnet-4-6.header_env]
authorization = "INFERENCEHUB_AUTHORIZATION"

[components.config.targets.claude-opus-4-6]
model = "azure/anthropic/claude-opus-4-6"
protocol = "openai_chat"
endpoint = "/v1/chat/completions"
base_url = "https://inference-api.nvidia.com"

[components.config.targets.claude-opus-4-6.header_env]
authorization = "INFERENCEHUB_AUTHORIZATION"

[components.config.targets.sonnet-responses]
model = "azure/anthropic/claude-sonnet-4-6"
protocol = "openai_responses"
endpoint = "/v1/responses"
base_url = "https://inference-api.nvidia.com"

[components.config.targets.sonnet-responses.header_env]
authorization = "INFERENCEHUB_AUTHORIZATION"

[components.config.targets.sonnet-anthropic]
model = "azure/anthropic/claude-sonnet-4-6"
protocol = "anthropic_messages"
endpoint = "/v1/messages"
base_url = "https://inference-api.nvidia.com"

[components.config.targets.sonnet-anthropic.header_env]
authorization = "INFERENCEHUB_AUTHORIZATION"

[[components]]
kind = "pricing"
enabled = true

[[components.config.sources]]
type = "file"
path = "@PRICING_CATALOG@"

[[components]]
kind = "observability"
enabled = true

[components.config.atof]
enabled = true
mode = "append"
output_directory = "@ATOF_DIR@"
filename = "trajectory.atof.jsonl"

[[components.config.atof.endpoints]]
url = "http://127.0.0.1:4000/v1/atof/events"
transport = "http_post"
field_name_policy = "preserve"
timeout_millis = 3000

[components.config.atof.endpoints.header_env]
authorization = "SWITCHYARD_AUTHORIZATION"

[components.config.atif]
enabled = true
agent_name = "Claude Code + Switchyard StageRouter"
agent_version = "inferencehub-claude-4.6-e2e"
model_name = "switchyard-stage-router"
output_directory = "@ATIF_DIR@"
filename_template = "trajectory-{session_id}.atif.json"
mark_projection = "tool"

[components.config.opentelemetry]
enabled = true
transport = "http_binary"
endpoint = "http://127.0.0.1:4318/v1/traces"
service_name = "nemo-relay-switchyard-inferencehub-e2e"
service_namespace = "switchyard-integration"
instrumentation_scope = "nemo-relay-switchyard"
timeout_millis = 5000

[components.config.opentelemetry.resource_attributes]
"deployment.environment.name" = "local-e2e"
"switchyard.profile.id" = "claude-4-6-stage-router"
