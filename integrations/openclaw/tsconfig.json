{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "openclaw/plugin-sdk/plugin-entry": ["./src/openclaw-plugin-entry.d.ts"],
      "nemo-flow-node": ["./src/openclaw-plugin-entry.d.ts"],
      "nemo-flow-node/plugin": ["./src/openclaw-plugin-entry.d.ts"]
    },
    "types": ["node"],
    "skipLibCheck": false,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.d.ts"]
}
