{
  "name": "@nvidia/nemo-flow-openclaw",
  "version": "0.2.0",
  "private": true,
  "description": "NeMo Flow-authored observability plugin for OpenClaw.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.6",
      "minGatewayVersion": "2026.5.6"
    },
    "build": {
      "openclawVersion": "2026.5.6",
      "pluginSdkVersion": "2026.5.6"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test \"dist/src/__tests__/*.test.js\"",
    "test:live": "npm run build && NEMO_FLOW_OPENCLAW_LIVE_SMOKE=1 node --test \"dist/src/__tests__/live-smoke.test.js\""
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.6"
  },
  "dependencies": {
    "nemo-flow-node": ">=0.1.0 <0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.2"
  },
  "license": "Apache-2.0"
}
